# ═══════════════════════════════════════════════════
#  StudyLock — docker-compose secrets template
# ═══════════════════════════════════════════════════
#
# Copy this file to `.env` (same folder as docker-compose.yml) and fill in
# your real values. `.env` is in .gitignore and will NEVER be committed —
# only this `.env.example` file is tracked by git.
#
# Usage:
#   cp .env.example .env
#   (edit .env with your real values)
#   docker compose up --build

# MySQL root password used by both the mysql and app containers
MYSQL_ROOT_PASSWORD=rootpass

# Your real OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-PUT-YOUR-REAL-KEY-HERE
